{
    "name": "fullstack",
    "version": "0.1.0",
    "private": true,
    "type": "commonjs",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx}\" \"prisma/**/*.ts\" --ignore-unknown",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:migrate:dev": "prisma migrate dev",
        "db:migrate:reset": "prisma migrate reset",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "db:generate": "prisma generate",
        "db:seed": "prisma db seed",
        "db:seed:dev": "tsx ./prisma/seed-dev.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "ci": "npm run lint:fix && npm run format && npm run test:coverage"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@marcuth/env": "^0.0.1",
        "@prisma/adapter-better-sqlite3": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "@types/bcrypt": "^6.0.0",
        "bcrypt": "^6.0.0",
        "cookie": "^1.1.1",
        "date-fns": "^4.1.0",
        "jsonwebtoken": "^9.0.3",
        "next": "16.1.6",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hook-form": "^7.71.2",
        "react-icons": "^5.5.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/cookie": "^0.6.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitest/coverage-v8": "^4.0.18",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "eslint-plugin-unused-imports": "^4.4.1",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prisma": "^7.4.2",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "typescript": "^5",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.18"
    }
}
